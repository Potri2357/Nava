SUPABASE_SERVICE_ROLE_KEY=

# === LLM ===
GEMINI_API_KEY=your_gemini_api_key

# === GitHub ===
GITHUB_PAT=your_github_personal_access_token

NEXT_PUBLIC_APP_URL=http://localhost:3000
